# Copie para .env e ajuste conforme o colégio / ano letivo.
COLEGIO_ID=29457
CICLO_ID=1476            # ano letivo corrente — atualizar anualmente
NIVEL_ID=33             # parâmetro nivelId da URL do professor — 33 funciona mesmo quando o portal indica 32
URL_PEGASUS=https://apps.uno-internacional.com/br/sumun/pegasus/dashboard
URL_BASE=https://apps.uno-internacional.com/br/sumun/pegasus
CDP_URL=http://localhost:9222
AUTH_MODE=manual         # "manual" = sessão CDP já aberta | "auto" = login automatizado (a implementar)
LOG_LEVEL=INFO
RETRY_MAX=3              # tentativas por professor com status parcial/erro/ambiguidade
